# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# custom next build output directories (BUILD_DIR=.next-build-*)
# Covers .next-build, .next-build-audit, .next-build-test, .next-build-ci,
# .next-build-release-audit, .next-build-final-check, and any ad-hoc
# BUILD_DIR=.next-build-<label> used during audit/build runs.
/.next-build*/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
