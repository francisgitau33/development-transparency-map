generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User profiles - core user data
model User {
  id             String   @id @default(cuid())
  email          String   @unique
  password       String
  displayName    String?
  organizationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization        Organization?        @relation(fields: [organizationId], references: [id])
  role                Role?
  pendingRequest      PendingAccessRequest?
  createdProjects     Project[]            @relation("CreatedBy")
  uploadJobs          UploadJob[]
  cmsUpdates          CmsAbout[]           @relation("UpdatedBy")
}

// Roles - only SYSTEM_OWNER and PARTNER_ADMIN
enum RoleType {
  SYSTEM_OWNER
  PARTNER_ADMIN
}

model Role {
  id             String   @id @default(cuid())
  userId         String   @unique
  email          String
  role           RoleType
  organizationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id])
}

// Pending access requests
enum RequestStatus {
  PENDING
  APPROVED
  DECLINED
}

model PendingAccessRequest {
  id               String        @id @default(cuid())
  userId           String        @unique
  email            String
  displayName      String?
  organizationName String?
  requestedAt      DateTime      @default(now())
  status           RequestStatus @default(PENDING)
  notes            String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Organization types
enum OrganizationType {
  LNGO
  INGO
  FOUNDATION
  GOVERNMENT
  OTHER
}

model Organization {
  id           String           @id @default(cuid())
  name         String
  type         OrganizationType
  countryCode  String
  website      String?
  contactEmail String?
  description  String?
  active       Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  users      User[]
  roles      Role[]
  projects   Project[]
  uploadJobs UploadJob[]
}

// Project status
enum ProjectStatus {
  ACTIVE
  PLANNED
  COMPLETED
}

// Project public-map visibility / approval state
// Only PUBLISHED projects are shown on the public map.
// Partner Admins can create/edit at DRAFT or PENDING_REVIEW.
// Only System Owners can set PUBLISHED or UNPUBLISHED.
enum ProjectVisibility {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  UNPUBLISHED
}

model Project {
  id                   String            @id @default(cuid())
  title                String
  description          String
  organizationId       String
  countryCode          String
  adminArea1           String?
  adminArea2           String?
  administrativeAreaId String?
  donorId              String?
  sectorKey            String
  status               ProjectStatus
  visibility           ProjectVisibility @default(PENDING_REVIEW)
  startDate            DateTime
  endDate              DateTime?
  budgetUsd            Float?
  targetBeneficiaries  Int?              // Number of people the project aims to reach/serve
  latitude             Float
  longitude            Float
  locationName         String?
  dataSource           String?
  contactEmail         String?
  createdByUserId      String
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  organization       Organization        @relation(fields: [organizationId], references: [id])
  createdBy          User                @relation("CreatedBy", fields: [createdByUserId], references: [id])
  administrativeArea AdministrativeArea? @relation(fields: [administrativeAreaId], references: [id])
  donor              Donor?              @relation(fields: [donorId], references: [id])

  @@index([visibility])
  @@index([administrativeAreaId])
  @@index([donorId])
  @@index([countryCode])
  @@index([sectorKey])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

// Reference countries
enum CountryType {
  COUNTRY
  TERRITORY
}

model ReferenceCountry {
  code      String      @id
  name      String
  type      CountryType @default(COUNTRY)
  active    Boolean     @default(true)
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  administrativeAreas AdministrativeArea[]
}

// Administrative Area / District-County reference data.
// Scoped to a ReferenceCountry. The `type` column captures the country's
// local naming convention ("District", "County", "Region", "Province",
// "State", …) so the UI can localise its label per-country in future.
model AdministrativeArea {
  id          String   @id @default(cuid())
  name        String
  type        String?  // e.g. District, County, Region, Province, State
  countryCode String
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)

  // Optional population metadata, used for population-weighted reporting
  // metrics (see src/lib/population-metrics.ts). All fields are OPTIONAL —
  // missing values must never break reports; downstream calculations fall
  // back to "Population data missing" / "Insufficient data" labels.
  //
  // - estimatedPopulation: must be POSITIVE if provided (> 0). Zero is
  //   explicitly rejected by validation so we never divide by zero in the
  //   per-capita widgets.
  // - populationYear: reasonable calendar year if provided
  //   (1900 ≤ y ≤ currentYear + 1 per validation).
  // - populationSource: free text (e.g. "National Census 2019") — if
  //   missing, reports show "Unsourced (completeness warning)".
  // - populationSourceUrl: optional URL back to the source dataset.
  // - populationNotes: free-form caveat (e.g. "projection", "includes
  //   informal settlements", "excludes refugee camps").
  estimatedPopulation Int?
  populationYear      Int?
  populationSource    String?
  populationSourceUrl String?
  populationNotes     String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  country  ReferenceCountry @relation(fields: [countryCode], references: [code])
  projects Project[]

  @@unique([countryCode, name])
  @@index([countryCode])
  @@index([active])
  @@index([sortOrder])
}

// Donor reference data. Used to tag which funder(s) back a project so the
// platform can answer "who funds what, where".
model Donor {
  id              String   @id @default(cuid())
  name            String   @unique
  donorType       String?  // Bilateral, Multilateral, Foundation, Corporate, Government, Individual, INGO, Pooled Fund, Other
  countryOfOrigin String?
  website         String?
  active          Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  projects Project[]

  @@index([active])
  @@index([sortOrder])
}

// Reference sectors
model ReferenceSector {
  key       String   @id
  name      String
  icon      String
  color     String
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// CMS About page
model CmsAbout {
  id              String   @id @default(cuid())
  title           String
  subtitle        String?
  bodySections    Json
  updatedAt       DateTime @updatedAt
  updatedByUserId String?

  updatedBy User? @relation("UpdatedBy", fields: [updatedByUserId], references: [id])
}

// Upload jobs for bulk CSV
enum UploadStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model UploadJob {
  id               String       @id @default(cuid())
  uploadedByUserId String
  organizationId   String
  uploadedAt       DateTime     @default(now())
  status           UploadStatus @default(PENDING)
  totalRows        Int          @default(0)
  validRows        Int          @default(0)
  invalidRows      Int          @default(0)
  errorReport      Json?
  fileName         String?

  uploadedBy   User         @relation(fields: [uploadedByUserId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
}

// Password reset tokens
model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

// Audit log for administrative / security-relevant events.
// Writes are best-effort: audit failures must not break the primary transaction
// (see src/lib/audit.ts).
model AuditEvent {
  id         String   @id @default(cuid())
  actorId    String?  // User.id of actor, nullable for system-originated events
  actorEmail String?  // snapshot of actor email for retention beyond user deletion
  action     String   // e.g. USER_APPROVED, PROJECT_CREATED, CMS_UPDATED
  entityType String?  // e.g. User, Project, Organization, CmsAbout
  entityId   String?  // id of the affected entity
  payload    Json?    // structured context (diff, params, counts, …)
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([actorId])
  @@index([action])
  @@index([entityType, entityId])
}