generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User profiles - core user data
model User {
  id             String   @id @default(cuid())
  email          String   @unique
  password       String
  displayName    String?
  organizationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization        Organization?        @relation(fields: [organizationId], references: [id])
  role                Role?
  pendingRequest      PendingAccessRequest?
  createdProjects     Project[]            @relation("CreatedBy")
  uploadJobs          UploadJob[]
  cmsUpdates          CmsAbout[]           @relation("UpdatedBy")
  cmsHomeUpdates      CmsHome[]            @relation("CmsHomeUpdatedBy")
  cmsPublicLinkUpdates CmsPublicLinks[]    @relation("CmsPublicLinksUpdatedBy")
}

// Roles - only SYSTEM_OWNER and PARTNER_ADMIN
enum RoleType {
  SYSTEM_OWNER
  PARTNER_ADMIN
}

model Role {
  id             String   @id @default(cuid())
  userId         String   @unique
  email          String
  role           RoleType
  organizationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id])
}

// Pending access requests
enum RequestStatus {
  PENDING
  APPROVED
  DECLINED
}

model PendingAccessRequest {
  id               String        @id @default(cuid())
  userId           String        @unique
  email            String
  displayName      String?
  organizationName String?
  requestedAt      DateTime      @default(now())
  status           RequestStatus @default(PENDING)
  notes            String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Organization types
enum OrganizationType {
  LNGO
  INGO
  FOUNDATION
  GOVERNMENT
  OTHER
}

// Organization country-of-operation scope.
// "ALL" represents global / unrestricted coverage — used for INGOs like World
// Vision, Save the Children, Plan International etc. When set to "ALL" the
// join table OrganizationCountry MUST be empty for that organization.
// "SELECTED" means the organization operates in one or more specific
// countries; OrganizationCountry rows define the selection.
enum CountryScope {
  ALL
  SELECTED
}

model Organization {
  id           String           @id @default(cuid())
  name         String
  type         OrganizationType

  // Legacy single-country column (PRD: Update implementing organization
  // setup to support multiple operating countries). Kept nullable for
  // backward compatibility — historic reads that still reference
  // `organization.countryCode` continue to work, but the authoritative
  // source of truth for country-of-operation is now
  // `countryScope` + `OrganizationCountry[]`.
  //
  // On write paths the API mirrors the first selected country back into
  // this column so that older dashboards / analytics that have not yet
  // been migrated keep working. A subsequent cleanup migration can drop
  // the column once all reads have been ported.
  countryCode  String?

  // Country-of-operation scope — either ALL or SELECTED. Defaulted to
  // SELECTED so existing rows are interpreted as "operates in one country".
  countryScope CountryScope     @default(SELECTED)

  website      String?
  contactEmail String?
  description  String?
  active       Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  users            User[]
  roles            Role[]
  projects         Project[]
  uploadJobs       UploadJob[]
  operatingCountries OrganizationCountry[]

  @@index([countryScope])
}

// Join table: organizations <-> reference countries. Only populated when
// Organization.countryScope == SELECTED. For ALL-scope organizations this
// table stays empty — the absence of rows + the scope flag together mean
// "global coverage".
//
// Deliberately NOT cascading on country delete: ReferenceCountry uses soft
// delete (deletedAt) so we keep the join row pointing at the historical
// country code, matching the existing pattern used for Project.countryCode.
model OrganizationCountry {
  organizationId String
  countryCode    String
  createdAt      DateTime @default(now())

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  country      ReferenceCountry @relation(fields: [countryCode], references: [code])

  @@id([organizationId, countryCode])
  @@index([countryCode])
  @@index([organizationId])
}

// Project status
enum ProjectStatus {
  ACTIVE
  PLANNED
  COMPLETED
}

// Project public-map visibility / approval state
// Only PUBLISHED projects are shown on the public map.
// Partner Admins can create/edit at DRAFT or PENDING_REVIEW.
// Only System Owners can set PUBLISHED or UNPUBLISHED.
enum ProjectVisibility {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  UNPUBLISHED
}

model Project {
  id                   String            @id @default(cuid())
  title                String
  description          String
  organizationId       String
  countryCode          String
  adminArea1           String?
  adminArea2           String?
  administrativeAreaId String?
  donorId              String?
  sectorKey            String
  status               ProjectStatus
  visibility           ProjectVisibility @default(PENDING_REVIEW)
  startDate            DateTime
  endDate              DateTime?
  budgetUsd            Float?
  targetBeneficiaries  Int?              // Number of people the project aims to reach/serve
  latitude             Float
  longitude            Float
  locationName         String?
  dataSource           String?
  contactEmail         String?
  // Optional donor / funding / grant reference code. NOT used by reports,
  // analytics, filters, charts, or data-quality scoring — see
  // src/lib/validation.ts::validateProject and the Reports page guard.
  donorFundingCode     String?
  createdByUserId      String
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  organization       Organization        @relation(fields: [organizationId], references: [id])
  createdBy          User                @relation("CreatedBy", fields: [createdByUserId], references: [id])
  administrativeArea AdministrativeArea? @relation(fields: [administrativeAreaId], references: [id])
  donor              Donor?              @relation(fields: [donorId], references: [id])

  @@index([visibility])
  @@index([administrativeAreaId])
  @@index([donorId])
  @@index([countryCode])
  @@index([sectorKey])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

// Reference countries
enum CountryType {
  COUNTRY
  TERRITORY
}

model ReferenceCountry {
  code      String      @id
  name      String
  type      CountryType @default(COUNTRY)
  active    Boolean     @default(true)
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // Soft-delete markers (Reference Data Delete — PRD §9.x).
  // When `deletedAt` is set, the row is considered removed: it is excluded
  // from every public GET, filter dropdown, and upload form. It remains in
  // the table so historical project / organization / indicator data that
  // still references the code keeps resolving. Hard-delete is never issued
  // for this table because the code column is used as a foreign key from
  // AdministrativeArea / CountryIndicator and as a string key from Project /
  // Organization.
  deletedAt       DateTime?
  deletedByUserId String?

  administrativeAreas  AdministrativeArea[]
  indicators           CountryIndicator[]
  organizationCountries OrganizationCountry[]

  @@index([deletedAt])
}

// Country Development Context indicators (Prompt 8 — Country Development
// Context Profile). One row per (country, indicator key, year). All fields
// except id/countryCode/indicatorKey/year are optional. Calculated values
// such as country population are derived from AdministrativeArea records
// at read time and are NEVER stored here (see src/lib/country-context.ts).
//
// CORE PRINCIPLE: indicator values are contextual data, not proof of need
// or effectiveness. The UI must always display them alongside their stated
// source + year.
//
// Allowed indicatorKey values are enforced in application code (not via
// a Prisma enum) so that new indicators can be added without a schema
// migration. See ALLOWED_INDICATOR_KEYS in src/lib/country-context.ts.
model CountryIndicator {
  id           String   @id @default(cuid())
  countryCode  String
  indicatorKey String
  year         Int

  // Numeric value. Some indicators (HDI) may carry only `rank`, so `value`
  // is nullable. `rank` is a positive integer where present (e.g. HDI
  // rank). `unit` is free-text ("USD", "%", "per 1,000 people", …).
  value        Float?
  rank         Int?
  unit         String?
  source       String?
  sourceUrl    String?
  notes        String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  country ReferenceCountry @relation(fields: [countryCode], references: [code], onDelete: Cascade)

  @@unique([countryCode, indicatorKey, year])
  @@index([countryCode])
  @@index([indicatorKey])
  @@index([year])
}

// Administrative Area / District-County reference data.
// Scoped to a ReferenceCountry. The `type` column captures the country's
// local naming convention ("District", "County", "Region", "Province",
// "State", …) so the UI can localise its label per-country in future.
model AdministrativeArea {
  id          String   @id @default(cuid())
  name        String
  type        String?  // e.g. District, County, Region, Province, State
  countryCode String
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)

  // Optional population metadata, used for population-weighted reporting
  // metrics (see src/lib/population-metrics.ts). All fields are OPTIONAL —
  // missing values must never break reports; downstream calculations fall
  // back to "Population data missing" / "Insufficient data" labels.
  //
  // - estimatedPopulation: must be POSITIVE if provided (> 0). Zero is
  //   explicitly rejected by validation so we never divide by zero in the
  //   per-capita widgets.
  // - populationYear: reasonable calendar year if provided
  //   (1900 ≤ y ≤ currentYear + 1 per validation).
  // - populationSource: free text (e.g. "National Census 2019") — if
  //   missing, reports show "Unsourced (completeness warning)".
  // - populationSourceUrl: optional URL back to the source dataset.
  // - populationNotes: free-form caveat (e.g. "projection", "includes
  //   informal settlements", "excludes refugee camps").
  estimatedPopulation Int?
  populationYear      Int?
  populationSource    String?
  populationSourceUrl String?
  populationNotes     String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Soft-delete markers (Reference Data Delete — PRD §9.x).
  // Mirrors ReferenceCountry: set `deletedAt` to hide the row from public
  // filters / upload forms / partner dropdowns without breaking historical
  // projects that still reference it. Hard-delete remains guarded (blocked
  // if any Project.administrativeAreaId matches).
  deletedAt       DateTime?
  deletedByUserId String?

  country  ReferenceCountry @relation(fields: [countryCode], references: [code])
  projects Project[]

  @@unique([countryCode, name])
  @@index([countryCode])
  @@index([active])
  @@index([sortOrder])
  @@index([deletedAt])
}

// Donor reference data. Used to tag which funder(s) back a project so the
// platform can answer "who funds what, where".
model Donor {
  id              String   @id @default(cuid())
  name            String   @unique
  donorType       String?  // Bilateral, Multilateral, Foundation, Corporate, Government, Individual, INGO, Pooled Fund, Other
  countryOfOrigin String?
  website         String?
  active          Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Soft-delete markers (Reference Data Delete — PRD §9.x).
  // Donors are referenced by Project.donorId. Setting `deletedAt` hides
  // the donor from public filters + upload templates + partner dropdowns
  // while keeping historical project attribution intact.
  deletedAt       DateTime?
  deletedByUserId String?

  projects Project[]

  @@index([active])
  @@index([sortOrder])
  @@index([deletedAt])
}

// Reference sectors
model ReferenceSector {
  key       String   @id
  name      String
  icon      String
  color     String
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft-delete markers (Reference Data Delete — PRD §9.x).
  // Sectors are referenced by Project.sectorKey. Setting `deletedAt` hides
  // the sector from public map filters + upload templates + project forms
  // while keeping historical project attribution intact.
  deletedAt       DateTime?
  deletedByUserId String?

  @@index([deletedAt])
}

// CMS About page
model CmsAbout {
  id              String   @id @default(cuid())
  title           String
  subtitle        String?
  bodySections    Json
  updatedAt       DateTime @updatedAt
  updatedByUserId String?

  updatedBy User? @relation("UpdatedBy", fields: [updatedByUserId], references: [id])
}

// CMS Home page content — single-row table (singleton) holding the
// SYSTEM_OWNER-editable copy for the public homepage hero section. The
// API keeps exactly one row at all times (creates one if none exists,
// always PATCHes the first row). If the row is missing, the public page
// falls back to the hardcoded BRANDING constants so the site never
// breaks because CMS data is absent.
model CmsHome {
  id                 String   @id @default(cuid())
  heroTitle          String
  heroSubtitle       String
  heroDescription    String?
  primaryCtaLabel    String?
  primaryCtaHref     String?
  secondaryCtaLabel  String?
  secondaryCtaHref   String?
  updatedAt          DateTime @updatedAt
  updatedByUserId    String?

  updatedBy User? @relation("CmsHomeUpdatedBy", fields: [updatedByUserId], references: [id])
}

// CMS Public Links — single-row table (singleton) holding configurable
// social-media URLs and the public contact email. All fields are
// optional: blank values simply cause the corresponding icon / line to
// be hidden publicly. Only SYSTEM_OWNER may mutate.
model CmsPublicLinks {
  id              String   @id @default(cuid())
  linkedinUrl     String?
  mediumUrl       String?
  contactEmail    String?
  updatedAt       DateTime @updatedAt
  updatedByUserId String?

  updatedBy User? @relation("CmsPublicLinksUpdatedBy", fields: [updatedByUserId], references: [id])
}

// Our Team — public CMS-managed list of team members. Only SYSTEM_OWNERs
// can mutate rows; the public GET endpoint returns active members only,
// ordered by (displayOrder asc, name asc). Photos are stored as free-form
// URLs (the platform has no built-in file-upload pipeline — Next.js is
// configured with `images.unoptimized: true`, so a plain <img src> works
// with any externally-hosted image without a remote-patterns entry).
model TeamMember {
  id           String   @id @default(cuid())
  name         String
  role         String
  bio          String?
  // Legacy external URL slot. Kept for backward compatibility with rows
  // that were created before the in-app photo-upload feature landed.
  // New CMS writes leave this null and populate photoData instead.
  photoUrl     String?
  // Uploaded-photo bytes stored in-database. Populated by the CMS photo
  // upload (JPEG / PNG only, size-capped, MIME sniffed on the server).
  // Served to the public /team page via GET /api/team/[id]/photo — the
  // raw bytes are NEVER returned by /api/team list/item endpoints so
  // large blobs don't bloat JSON responses.
  photoData     Bytes?
  photoMimeType String?
  linkedinUrl  String?
  displayOrder Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active, displayOrder])
}

// Upload jobs for bulk CSV
enum UploadStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model UploadJob {
  id               String       @id @default(cuid())
  uploadedByUserId String
  organizationId   String
  uploadedAt       DateTime     @default(now())
  status           UploadStatus @default(PENDING)
  totalRows        Int          @default(0)
  validRows        Int          @default(0)
  invalidRows      Int          @default(0)
  errorReport      Json?
  fileName         String?

  uploadedBy   User         @relation(fields: [uploadedByUserId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
}

// Password reset tokens
model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

// Audit log for administrative / security-relevant events.
// Writes are best-effort: audit failures must not break the primary transaction
// (see src/lib/audit.ts).
model AuditEvent {
  id         String   @id @default(cuid())
  actorId    String?  // User.id of actor, nullable for system-originated events
  actorEmail String?  // snapshot of actor email for retention beyond user deletion
  action     String   // e.g. USER_APPROVED, PROJECT_CREATED, CMS_UPDATED
  entityType String?  // e.g. User, Project, Organization, CmsAbout
  entityId   String?  // id of the affected entity
  payload    Json?    // structured context (diff, params, counts, …)
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([actorId])
  @@index([action])
  @@index([entityType, entityId])
}